PROGRAM 2
#!/usr/bin/awk -f

BEGIN {
    print "Enter the range : "
    getline n < "-"
    print "Fibonacci Series till", n, ":"

    a = 0
    b = 1

    print a

    for (i = 1; i <= n; i += 1) {
        c = a + b
        print c
        a = b
        b = c
    }
}

