PROGRAM 3 
#!/usr/bin/perl

print "Enter the number\n";
$num = <>;
chomp($num);

$flag = 0;

for ($i = 2; $i < $num; $i += 1) {
    if ($num % $i == 0) {
        $flag = 1;
        last;
    }
}

if ($flag == 1) {
    print "Not Prime Number\n";
} else {
    print "Prime Number\n";
}
