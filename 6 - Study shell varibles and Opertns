#!bin/sh 
#Logical Operator 
read -p 'Enter Value of A:' a 
read -p 'Enter Value of B:' b 
echo $a  
echo $b 
if(($a=="true" && $b=="true")) 
then  
echo "Both the values are true" 
else 
echo "both are not true" 
fi 
if(($a=="true" || $b=="true")) 
then  
echo "Atlest one of them is true" 
else 
echo "none of them is true" 
fi 
if((!$a=="true")) 
then  
echo "A is False" 
else 
echo "A is true" 
fi 
if((!$b=="true")) 
then  
echo "B is False" 
else 
echo "B is true" 
fi 
